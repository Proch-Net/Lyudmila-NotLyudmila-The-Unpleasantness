    $ send_ok("Антон", "Слушай, пошли гулять завтра", "right")
    pause 1.5
    play sound "audio/ok.ogg"
    $ send_ok("Марина", "всм, куда?", "left")
    pause 2.5
    play sound "audio/ok.ogg"
    $ send_ok("Антон", "Ну... Может, в Зубаревский лес? Там красиво, и воздух свежий", "right")
    pause 2.5
    play sound "audio/ok.ogg"
    $ send_ok("Марина", "ааа... Ну давай, как хочешь. Я не против", "left")
    pause 3.5
    # Игрок должен кликнуть, чтобы закрыть телефон
    "Мысли: Ура! Она согласилась!"
    hide screen ok_messenger with moveoutbottom
    jump ending


label lox:
    stop music fadeout 2.0
    play music "audio/lox.ogg" fadein 2.0
    "Вы отбросили мысли и продолжили лежать на диване."
    "Вы остались девственником и чмом по жизни."
    "Вы ничего не добьетесь в жизни, ваша судьба решена."
    scene pososi with dissolve
    "От разработчика: Пошел нахуй, лох, ссыкло ебаное."
    $ renpy.pause(1.0, hard=True)
    jump ending

label ending:
    # Прячем диалоговое окно
    window hide

    # Останавливаем музыку
    stop music fadeout 2.0

    # Воспроизводим музыку для концовки
    play music "audio/end.ogg" fadein 2.0

    # Уходим в затемнение
    scene black with fade

    # Показываем пашу с пузом
    show pasha def at right with dissolve
    
    # Выводим наш текст с применением анимации
    show text credits_text at credits_scroll
    
    # ВАЖНО: Ставим хард-паузу на время прокрутки (15 секунд + 2 секунды запаса, чтобы экран не мигнул)
    # hard=True не даст игроку случайно скипнуть титры кликом мыши
    $ renpy.pause(17.0, hard=True)
    
    # Гасим музыку и возвращаемся в главное меню
    hide lyudmila with dissolve
    stop music fadeout 2.0
    scene black with fade
    return
