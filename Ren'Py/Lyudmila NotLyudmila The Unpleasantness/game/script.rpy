default ok_messages = []

init python:
    # Создаем контроллер прокрутки
    ok_yadj = ui.adjustment()

    # Функция для быстрой отправки сообщений
    def send_ok(sender, text, align):
        # align может быть "left" (входящие) или "right" (твои исходящие)
        ok_messages.append({"sender": sender, "text": text, "align": align})
        # Задаем искусственно огромное число, чтобы движок прокрутил в самый низ
        ok_yadj.value = 9999999

