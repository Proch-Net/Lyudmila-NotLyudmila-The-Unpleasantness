transform fall_trip_slow:
    xalign 0.2 yalign 1.0
    pause 0.5                # Ждем полсекунды, прежде чем начать падать
    parallel:
        easein 1.0 yoffset 600   # Падение теперь длится целую секунду (было 0.3)
    parallel:
        easein 1.0 rotate -45    # Поворот тоже замедлен до 1 секунды

transform smooth_flip:
    linear 0.5 xzoom -1.0  # Разворот за полсекунды

# Анимация "Киношный скролл"
transform credits_scroll:
    # ypos 1.0 - это нижний край экрана. yanchor 0.0 - верхний край самого текста.
    # То есть текст начинает путь ровно ПОД экраном.
    ypos 1.0 yanchor 0.0
    xalign 0.3
    # linear 15.0 - это время прокрутки (15 секунд). Чем больше текст, тем больше делай цифру.
    # ypos 0.0 yanchor 1.0 - означает, что текст уползет ровно ЗА верхний край экрана.
    linear 15.0 ypos 0.0 yanchor 1.0

transform constant_shake:
    # Смещаем спрайт влево-вправо на 5 пикселей каждые 0.05 секунд
    linear 0.05 xoffset 5
    linear 0.05 xoffset -5
    repeat # Зацикливает анимацию

