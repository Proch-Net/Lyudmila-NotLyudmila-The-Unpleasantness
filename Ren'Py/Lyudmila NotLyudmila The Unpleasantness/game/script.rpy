label splashscreen:
    # 1. Сначала полная темнота
    scene black
    pause 0.5

    # 2. Показываем логотип твоей студии или просто название игры
    # Предположим, файл называется 'splash_logo.png' в папке images
    show splash_logo at center with dissolve
    
    # Заставляем игрока смотреть на это 2 секунды
    pause 2.0
    
    # 3. Плавно убираем логотип в черноту
    hide splash_logo with dissolve
    pause 1.0

    # После этого движок АВТОМАТИЧЕСКИ перейдет в главное меню
    return

